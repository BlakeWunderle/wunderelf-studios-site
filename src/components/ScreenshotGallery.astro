---
interface Props {
  images: { src: string; alt: string }[];
}

const { images } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  {images.map((img) => (
    <button
      class="screenshot-thumb group relative overflow-hidden rounded-lg border border-dark-border hover:border-teal/50 transition-colors cursor-pointer"
      data-full={img.src}
      aria-label={`View full: ${img.alt}`}
    >
      <img
        src={img.src}
        alt={img.alt}
        class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-dark-bg/0 group-hover:bg-dark-bg/20 transition-colors" />
    </button>
  ))}
</div>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-dark-bg/90 backdrop-blur-sm cursor-pointer">
  <button class="absolute top-6 right-6 text-text-muted hover:text-white text-3xl" aria-label="Close">&times;</button>
  <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] rounded-lg" />
</div>

<script>
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;

  document.querySelectorAll(".screenshot-thumb").forEach((thumb) => {
    thumb.addEventListener("click", () => {
      const src = (thumb as HTMLElement).dataset.full;
      if (src && lightbox && lightboxImg) {
        lightboxImg.src = src;
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
      }
    });
  });

  lightbox?.addEventListener("click", () => {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
    }
  });
</script>

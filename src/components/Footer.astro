---
const year = new Date().getFullYear();
---

<footer class="border-t border-dark-border bg-dark-surface">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <img src="/images/wunderelf-logo.webp" alt="Wunderelf Studios" class="w-8 h-8 rounded" />
          <span class="font-heading text-xl font-bold text-teal-light">Wunderelf Studios</span>
        </div>
        <p class="mt-3 text-sm text-text-muted leading-relaxed">
          Where stories become adventures.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-text-muted mb-4">Navigate</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-text-muted hover:text-teal-light transition-colors">Home</a></li>
          <li><a href="/echoes-of-choice" class="text-sm text-text-muted hover:text-teal-light transition-colors">Echoes of Choice</a></li>
          <li><a href="/about" class="text-sm text-text-muted hover:text-teal-light transition-colors">About</a></li>
          <li><a href="/press" class="text-sm text-text-muted hover:text-teal-light transition-colors">Press Kit</a></li>
          <li><a href="/contact" class="text-sm text-text-muted hover:text-teal-light transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-text-muted mb-4">Connect</h3>
        <div class="flex gap-4">
          <a href="#" class="text-text-muted hover:text-teal-light transition-colors" aria-label="Steam">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.979 0C5.678 0 .511 4.86.022 10.94l6.432 2.658a3.387 3.387 0 0 1 1.912-.588c.063 0 .125.002.188.006l2.861-4.142V8.77c0-2.427 1.975-4.4 4.404-4.4 2.427 0 4.402 1.975 4.402 4.404 0 2.427-1.975 4.4-4.402 4.4h-.1l-4.076 2.91c0 .05.004.1.004.15 0 1.822-1.48 3.303-3.303 3.303a3.308 3.308 0 0 1-3.257-2.748L.596 13.822C1.87 19.558 6.44 24 11.979 24c6.627 0 12-5.373 12-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61a2.48 2.48 0 0 0 1.348 1.349 2.478 2.478 0 0 0 3.256-3.098 2.478 2.478 0 0 0-3.131-1.641zm8.277-9.44a2.94 2.94 0 0 1-2.938-2.938 2.94 2.94 0 0 1 2.938-2.938 2.94 2.94 0 0 1 2.937 2.938 2.94 2.94 0 0 1-2.937 2.937z"/>
            </svg>
          </a>
          <a href="#" class="text-text-muted hover:text-teal-light transition-colors" aria-label="Twitter/X">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-dark-border text-center">
      <p class="text-xs text-text-muted">
        &copy; {year} Wunderelf Studios. All rights reserved.
      </p>
    </div>
  </div>
</footer>

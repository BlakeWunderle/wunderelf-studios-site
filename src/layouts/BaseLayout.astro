---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Wunderelf Studios — Crafting narrative RPGs where every choice leaves a shadow.",
  ogImage = "/images/capsule.png",
} = Astro.props;

const siteTitle = title === "Home" ? "Wunderelf Studios" : `${title} | Wunderelf Studios`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oswald:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <title>{siteTitle}</title>

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0EMN4LFZWG"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0EMN4LFZWG');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      document.addEventListener('click', function(e) {
        var link = e.target.closest('[data-track="steam_click"]');
        if (link && typeof gtag !== 'undefined') {
          gtag('event', 'steam_click', {
            event_category: 'outbound',
            event_label: link.dataset.location || 'unknown',
            transport_type: 'beacon'
          });
        }
      });
    </script>
  </body>
</html>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ScreenshotGallery from "../components/ScreenshotGallery.astro";

const screenshots = [
  { src: "/images/screenshot-1.webp", alt: "Title screen" },
  { src: "/images/screenshot-2.webp", alt: "Story selection" },
  { src: "/images/screenshot-3.webp", alt: "Class selection" },
  { src: "/images/screenshot-4.webp", alt: "Narrative text" },
  { src: "/images/screenshot-5.webp", alt: "Branching choice" },
  { src: "/images/screenshot-6.webp", alt: "Battle combat" },
  { src: "/images/screenshot-7.webp", alt: "Battle summary" },
  { src: "/images/screenshot-8.webp", alt: "Class upgrade" },
  { src: "/images/screenshot-9.webp", alt: "Compendium" },
];
---

<BaseLayout
  title="Echoes of Choice"
  description="A narrative RPG where every choice echoes through the story. 56 classes, branching storylines, and co-op play."
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <img src="/images/hero.webp" alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-dark-bg/70" />
    <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-transparent to-dark-bg/80" />

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-heading text-5xl md:text-7xl font-bold mb-4">
        <span class="text-gold">Echoes</span> of <span class="text-gold">Choice</span>
      </h1>
      <p class="text-xl text-text-muted mb-8 max-w-xl mx-auto">
        Every decision shapes the world. Every echo tells a story.
      </p>
      <a
        href="#"
        class="inline-flex items-center gap-3 px-8 py-4 bg-[#1b2838] hover:bg-[#2a475e] text-white font-heading font-bold text-lg rounded-lg transition-colors border border-[#2a475e]"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.979 0C5.678 0 .511 4.86.022 10.94l6.432 2.658a3.387 3.387 0 0 1 1.912-.588c.063 0 .125.002.188.006l2.861-4.142V8.77c0-2.427 1.975-4.4 4.404-4.4 2.427 0 4.402 1.975 4.402 4.404 0 2.427-1.975 4.4-4.402 4.4h-.1l-4.076 2.91c0 .05.004.1.004.15 0 1.822-1.48 3.303-3.303 3.303a3.308 3.308 0 0 1-3.257-2.748L.596 13.822C1.87 19.558 6.44 24 11.979 24c6.627 0 12-5.373 12-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61a2.48 2.48 0 0 0 1.348 1.349 2.478 2.478 0 0 0 3.256-3.098 2.478 2.478 0 0 0-3.131-1.641zm8.277-9.44a2.94 2.94 0 0 1-2.938-2.938 2.94 2.94 0 0 1 2.938-2.938 2.94 2.94 0 0 1 2.937 2.938 2.94 2.94 0 0 1-2.937 2.937z"/>
        </svg>
        Wishlist on Steam
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 bg-dark-surface">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Features</h2>
        <div class="w-16 h-1 bg-gold mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard
          icon="&#x2694;"
          title="ATB Combat"
          description="Speed-based Active Time Battle system with turn order prediction. Position your party, manage abilities, and outmaneuver enemies."
        />
        <FeatureCard
          icon="&#x1F3AD;"
          title="56 Unique Classes"
          description="6 base classes branch into 16 Tier 1 and 34 Tier 2 specializations. From Squire to Dragoon, Mage to Chronomancer."
        />
        <FeatureCard
          icon="&#x1F333;"
          title="3 Story Campaigns"
          description="Three interconnected stories with branching paths, unique enemies, and endings shaped by your choices along the way."
        />
        <FeatureCard
          icon="&#x1F91D;"
          title="Co-op Multiplayer"
          description="Play locally with 2-3 players or online. Vote on story branches together. Each player controls their own party member."
        />
        <FeatureCard
          icon="&#x2728;"
          title="140+ Abilities"
          description="Damage, healing, buffs, debuffs, and terrain effects. Each class brings a unique toolkit to the party."
        />
        <FeatureCard
          icon="&#x1F504;"
          title="High Replayability"
          description="Branch points create different paths through each story. Multiple endings reward different choices and party compositions."
        />
      </div>
    </div>
  </section>

  <!-- Class System -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">The Class System</h2>
        <div class="w-16 h-1 bg-teal mx-auto rounded-full" />
        <p class="text-text-muted mt-6 max-w-2xl mx-auto leading-relaxed">
          Start as one of six base classes and evolve through two tiers of specialization.
          Your class choice shapes your combat role, abilities, and how you experience each story.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {[
          { name: "Squire", desc: "Physical fighters", color: "text-red-400" },
          { name: "Mage", desc: "Arcane casters", color: "text-blue-400" },
          { name: "Entertainer", desc: "Support & buffs", color: "text-purple-400" },
          { name: "Tinker", desc: "Inventors", color: "text-amber-400" },
          { name: "Wildling", desc: "Nature & beasts", color: "text-green-400" },
          { name: "Wanderer", desc: "Magic defense", color: "text-cyan-400" },
        ].map((cls) => (
          <div class="bg-dark-card border border-dark-border rounded-lg p-4 text-center hover:border-teal/50 transition-colors">
            <h4 class:list={["font-heading font-bold text-lg mb-1", cls.color]}>{cls.name}</h4>
            <p class="text-xs text-text-muted">{cls.desc}</p>
          </div>
        ))}
      </div>

      <p class="text-center text-text-muted text-sm mt-8">
        Each base class branches into 2-3 Tier 1 specializations, then 2-3 Tier 2 masteries.
      </p>
    </div>
  </section>

  <!-- Stories -->
  <section class="py-24 bg-dark-surface">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Three Stories. Your Choices.</h2>
        <div class="w-16 h-1 bg-gold mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-dark-card border border-dark-border rounded-xl p-8 hover:border-teal/50 transition-colors">
          <div class="text-sm font-heading text-teal-light uppercase tracking-wider mb-2">Story I</div>
          <h3 class="font-heading text-2xl font-bold mb-3">The Stranger's Shadow</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            A mysterious stranger offers your party a quest. As you journey through cities and forests,
            the line between ally and enemy blurs. Nothing is as it seems.
          </p>
        </div>

        <div class="bg-dark-card border border-dark-border rounded-xl p-8 hover:border-teal/50 transition-colors">
          <div class="text-sm font-heading text-teal-light uppercase tracking-wider mb-2">Story II</div>
          <h3 class="font-heading text-2xl font-bold mb-3">Echoes in the Dark</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            You awaken in a cave with no memory. As you piece together fragments of the past,
            a companion named Sera holds secrets that could change everything.
          </p>
        </div>

        <div class="bg-dark-card border border-dark-border rounded-xl p-8 hover:border-teal/50 transition-colors">
          <div class="text-sm font-heading text-teal-light uppercase tracking-wider mb-2">Story III</div>
          <h3 class="font-heading text-2xl font-bold mb-3">The Woven Night</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Shared dreams bind a town in mystery. As nightmares grow stronger,
            a cult's conspiracy threatens to unravel the boundary between dream and reality.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Screenshots</h2>
        <div class="w-16 h-1 bg-teal mx-auto rounded-full" />
      </div>

      <ScreenshotGallery images={screenshots} />

      <p class="text-center text-text-muted text-sm mt-8">
        Screenshots are from development. Final visuals may differ.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-dark-surface">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-6">Ready to Choose Your Path?</h2>
      <p class="text-text-muted mb-10 text-lg">
        Wishlist Echoes of Choice on Steam and be the first to play when it launches.
      </p>
      <a
        href="#"
        class="inline-flex items-center gap-3 px-10 py-4 bg-gold hover:bg-gold-light text-dark-bg font-heading font-bold text-xl rounded-lg transition-colors"
      >
        Wishlist on Steam
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeatureCard from "../components/FeatureCard.astro";
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-dark-bg via-dark-surface to-dark-bg" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--color-teal-dark)_0%,_transparent_70%)] opacity-20" />

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <img src="/images/wunderelf-logo.webp" alt="Wunderelf Studios" class="w-32 h-32 md:w-40 md:h-40 mx-auto mb-8 rounded-2xl" />
      <h1 class="font-heading text-5xl md:text-7xl font-bold mb-6 leading-tight">
        <span class="text-teal-light">Wunderelf</span> Studios
      </h1>
      <p class="text-xl md:text-2xl text-text-muted mb-10 max-w-2xl mx-auto leading-relaxed">
        Where stories become adventures.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/echoes-of-choice"
          class="inline-flex items-center justify-center px-8 py-3 bg-teal hover:bg-teal-light text-white font-heading font-bold text-lg rounded-lg transition-colors"
        >
          Our Latest Game
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center px-8 py-3 border border-dark-border hover:border-teal text-text-muted hover:text-teal-light font-heading font-bold text-lg rounded-lg transition-colors"
        >
          About Us
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Game -->
  <section class="py-24 bg-dark-surface">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Featured Game</h2>
        <div class="w-16 h-1 bg-teal mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="aspect-video rounded-xl border border-dark-border overflow-hidden">
          <img src="/images/capsule.webp" alt="Echoes of Choice" class="w-full h-full object-cover" />
        </div>

        <div>
          <h3 class="font-heading text-3xl font-bold mb-4 text-gold">Echoes of Choice</h3>
          <p class="text-text-muted leading-relaxed mb-6">
            A narrative RPG where your decisions shape the world. Build a party of three from 56 unique classes,
            battle through branching storylines, and discover that every choice carries weight.
            Three interconnected stories. Hundreds of paths. No two playthroughs are the same.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <span class="px-3 py-1 bg-dark-card border border-dark-border rounded-full text-xs text-text-muted">RPG</span>
            <span class="px-3 py-1 bg-dark-card border border-dark-border rounded-full text-xs text-text-muted">Turn-Based</span>
            <span class="px-3 py-1 bg-dark-card border border-dark-border rounded-full text-xs text-text-muted">Branching Narrative</span>
            <span class="px-3 py-1 bg-dark-card border border-dark-border rounded-full text-xs text-text-muted">Co-op</span>
          </div>
          <a
            href="/echoes-of-choice"
            class="inline-flex items-center gap-2 px-6 py-3 bg-gold hover:bg-gold-light text-dark-bg font-heading font-bold rounded-lg transition-colors"
          >
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Studio Values -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">What We Believe</h2>
        <div class="w-16 h-1 bg-teal mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <FeatureCard
          icon="&#x1F4D6;"
          title="Stories Worth Telling"
          description="We build worlds you want to live in. Every game starts with a story worth experiencing, then we build the systems to bring it to life."
        />
        <FeatureCard
          icon="&#x269B;"
          title="Choices That Matter"
          description="Inspired by years of tabletop RPGs, we design branching narratives where your decisions have real consequences, not the illusion of them."
        />
        <FeatureCard
          icon="&#x2728;"
          title="Built With Care"
          description="One studio, one game at a time. We'd rather build something we're proud of than rush to ship."
        />
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ScreenshotGallery from "../components/ScreenshotGallery.astro";

const screenshots = [
  { src: "/images/screenshot-1.webp", alt: "Title screen" },
  { src: "/images/screenshot-2.webp", alt: "Story selection" },
  { src: "/images/screenshot-3.webp", alt: "Class selection" },
  { src: "/images/screenshot-4.webp", alt: "Narrative text" },
  { src: "/images/screenshot-5.webp", alt: "Branching choice" },
  { src: "/images/screenshot-6.webp", alt: "Battle action menu" },
  { src: "/images/screenshot-7.webp", alt: "Battle summary" },
  { src: "/images/screenshot-8.webp", alt: "Class upgrade" },
  { src: "/images/screenshot-9.webp", alt: "Cinematic title card" },
  { src: "/images/screenshot-10.webp", alt: "Compendium classes" },
  { src: "/images/screenshot-11.webp", alt: "Battle action selection" },
  { src: "/images/screenshot-12.webp", alt: "Character stats panel" },
  { src: "/images/screenshot-13.webp", alt: "Multiplayer battle" },
];
---

<BaseLayout
  title="Parting Shadows"
  description="A narrative RPG of branching paths and shadowed choices. 56 classes, three story campaigns, and co-op play."
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <img src="/images/hero.png" alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-dark-bg/70" />
    <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-transparent to-dark-bg/80" />

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-heading text-5xl md:text-7xl font-bold mb-4">
        Parting <span class="text-gold">Shadows</span>
      </h1>
      <p class="text-xl text-text-muted mb-8 max-w-xl mx-auto">
        Every decision shapes the world. Every shadow hides a story.
      </p>
      <a
        href="https://store.steampowered.com/app/4545380/Parting_Shadows/?utm_source=wunderelf&utm_medium=website&utm_campaign=steam_button&utm_content=hero"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-8 py-4 bg-[#1b2838] hover:bg-[#2a475e] text-white font-heading font-bold text-lg rounded-lg transition-colors border border-[#2a475e]"
        data-track="steam_click"
        data-location="hero"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.979 0C5.678 0 .511 4.86.022 10.94l6.432 2.658a3.387 3.387 0 0 1 1.912-.588c.063 0 .125.002.188.006l2.861-4.142V8.77c0-2.427 1.975-4.4 4.404-4.4 2.427 0 4.402 1.975 4.402 4.404 0 2.427-1.975 4.4-4.402 4.4h-.1l-4.076 2.91c0 .05.004.1.004.15 0 1.822-1.48 3.303-3.303 3.303a3.308 3.308 0 0 1-3.257-2.748L.596 13.822C1.87 19.558 6.44 24 11.979 24c6.627 0 12-5.373 12-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61a2.48 2.48 0 0 0 1.348 1.349 2.478 2.478 0 0 0 3.256-3.098 2.478 2.478 0 0 0-3.131-1.641zm8.277-9.44a2.94 2.94 0 0 1-2.938-2.938 2.94 2.94 0 0 1 2.938-2.938 2.94 2.94 0 0 1 2.937 2.938 2.94 2.94 0 0 1-2.937 2.937z"/>
        </svg>
        View on Steam
      </a>
    </div>
  </section>

  <!-- Trailer -->
  <section class="py-20 px-4 bg-dark-bg">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Watch the Trailer</h2>
        <div class="w-16 h-1 bg-gold mx-auto rounded-full" />
      </div>
      <div class="aspect-video rounded-xl overflow-hidden border border-dark-border shadow-2xl">
        <iframe
          class="w-full h-full"
          src="https://www.youtube.com/embed/MBQrINcXLOI"
          title="Parting Shadows — Official Trailer"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 bg-dark-surface">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Features</h2>
        <div class="w-16 h-1 bg-gold mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <FeatureCard
          title="ATB Combat"
          description="Speed determines who acts first. A turn order bar shows upcoming turns so you can plan ahead. Physical attacks, magic, buffs, debuffs, and terrain abilities all factor into every fight. Crits, dodges, and status effects keep combat dynamic."
        />
        <FeatureCard
          title="56 Unique Classes"
          description="Start as one of six base classes, then specialize through two upgrade tiers. A Squire can become a Duelist and then a Dragoon. A Mage can become an Acolyte and then a Warlock. Every path plays differently, with unique abilities and stat growth."
        />
        <FeatureCard
          title="3 Story Campaigns"
          description="Each story is a self-contained adventure with its own cast, enemies, and branching paths. Choices at key moments split the narrative into genuinely different routes with unique battles and endings. One playthrough sees roughly half the content."
        />
        <FeatureCard
          title="Co-op Multiplayer"
          description="Play with 2-3 friends locally or online. Each player creates and controls their own party member. When the story branches, the group votes on which path to take. Drop-in works mid-game, and AI takes over if someone disconnects."
        />
        <FeatureCard
          title="140+ Abilities"
          description="Every class has its own ability set. Paladins heal and shield. Bombardiers deal AoE explosive damage. Chronomancers manipulate turn order. Shapeshifters transform for melee power. Building a party means combining toolkits that complement each other."
        />
        <FeatureCard
          title="High Replayability"
          description="Three stories with multiple branch points each. Different class compositions change how fights play out. A party of tanks and healers survives differently than a glass cannon team. The compendium tracks every enemy and class you discover across runs."
        />
      </div>
    </div>
  </section>

  <!-- Class System -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">The Class System</h2>
        <div class="w-16 h-1 bg-teal mx-auto rounded-full" />
        <p class="text-text-muted mt-6 max-w-2xl mx-auto leading-relaxed">
          Start as one of six base classes and evolve through two tiers of specialization.
          Your class choice shapes your combat role, abilities, and how you experience each story.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            name: "Squire",
            desc: "Physical fighters who master weapons and martial arts.",
            color: "text-red-400",
            border: "hover:border-red-400/50",
            branches: "Duelist, Ranger, Martial Artist \u2192 Cavalry, Dragoon, Mercenary, Hunter, Ninja, Monk",
          },
          {
            name: "Mage",
            desc: "Arcane casters wielding elemental and divine magic.",
            color: "text-blue-400",
            border: "hover:border-blue-400/50",
            branches: "Invoker, Acolyte \u2192 Infernalist, Tidecaller, Tempest, Paladin, Priest, Warlock",
          },
          {
            name: "Entertainer",
            desc: "Performers who inspire allies and demoralize enemies.",
            color: "text-purple-400",
            border: "hover:border-purple-400/50",
            branches: "Bard, Dervish, Orator \u2192 Warcrier, Minstrel, Illusionist, Mime, Laureate, Elegist",
          },
          {
            name: "Tinker",
            desc: "Inventors and academics who blend science with magic.",
            color: "text-amber-400",
            border: "hover:border-amber-400/50",
            branches: "Artificer, Philosopher, Arithmancer \u2192 Alchemist, Bombardier, Chronomancer, Astronomer, Automaton, Technomancer",
          },
          {
            name: "Wildling",
            desc: "Nature wielders who command plants, spirits, and beasts.",
            color: "text-green-400",
            border: "hover:border-green-400/50",
            branches: "Herbalist, Shaman, Beastcaller \u2192 Blighter, Grove Keeper, Witch Doctor, Spiritwalker, Falconer, Shapeshifter",
          },
          {
            name: "Wanderer",
            desc: "Wilderness fighters specializing in magic defense. Unlocked by completing Story I.",
            color: "text-cyan-400",
            border: "hover:border-cyan-400/50",
            branches: "Sentinel, Pathfinder \u2192 Bulwark, Aegis, Trailblazer, Survivalist",
          },
        ].map((cls) => (
          <div class:list={["bg-dark-card border border-dark-border rounded-xl p-6 transition-colors", cls.border]}>
            <h4 class:list={["font-heading font-bold text-xl mb-2", cls.color]}>{cls.name}</h4>
            <p class="text-sm text-text-muted leading-relaxed mb-3">{cls.desc}</p>
            <p class="text-xs text-text-muted/70 leading-relaxed">
              <span class="text-text-muted font-medium">Upgrades:</span> {cls.branches}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stories -->
  <section class="py-24 bg-dark-surface">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Three Stories. Your Choices.</h2>
        <div class="w-16 h-1 bg-gold mx-auto rounded-full" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-dark-card border border-dark-border rounded-xl p-8 hover:border-teal/50 transition-colors">
          <div class="text-sm font-heading text-teal-light uppercase tracking-wider mb-2">Story I</div>
          <h3 class="font-heading text-2xl font-bold mb-3">The Stranger's Shadow</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            A mysterious stranger offers your party a quest. As you journey through cities and forests,
            the line between ally and enemy blurs. Nothing is as it seems.
          </p>
        </div>

        <div class="bg-dark-card border border-dark-border rounded-xl p-8 hover:border-teal/50 transition-colors">
          <div class="text-sm font-heading text-teal-light uppercase tracking-wider mb-2">Story II</div>
          <h3 class="font-heading text-2xl font-bold mb-3">Echoes in the Dark</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            You awaken in a cave with no memory. As you piece together fragments of the past,
            a companion named Sera holds secrets that could change everything.
          </p>
        </div>

        <div class="bg-dark-card border border-dark-border rounded-xl p-8 hover:border-teal/50 transition-colors">
          <div class="text-sm font-heading text-teal-light uppercase tracking-wider mb-2">Story III</div>
          <h3 class="font-heading text-2xl font-bold mb-3">The Woven Night</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Shared dreams bind a town in mystery. As nightmares grow stronger,
            a cult's conspiracy threatens to unravel the boundary between dream and reality.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">Screenshots</h2>
        <div class="w-16 h-1 bg-teal mx-auto rounded-full" />
      </div>

      <ScreenshotGallery images={screenshots} />

      <p class="text-center text-text-muted text-sm mt-8">
        Screenshots are from development. Final visuals may differ.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-dark-surface">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-6">Ready to Choose Your Path?</h2>
      <p class="text-text-muted mb-10 text-lg">
        Parting Shadows is coming to Steam in April 2026. Wishlist now to get notified at launch.
      </p>
      <a
        href="https://store.steampowered.com/app/4545380/Parting_Shadows/?utm_source=wunderelf&utm_medium=website&utm_campaign=steam_button&utm_content=cta"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-10 py-4 bg-gold hover:bg-gold-light text-dark-bg font-heading font-bold text-xl rounded-lg transition-colors"
        data-track="steam_click"
        data-location="cta"
      >
        View on Steam
      </a>
    </div>
  </section>
</BaseLayout>
